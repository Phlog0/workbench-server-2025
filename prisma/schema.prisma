generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String      @id @default(uuid())
  projectType   ProjectType @default(КТП)
  title         String
  description   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime?   @updatedAt
  projectScheme Json?
}

enum ProjectType {
  ТП
  КТП
  РП
}

model User {
  id             Int             @id @default(autoincrement())
  firstName      String
  secondName     String
  password       String
  email          String          @unique
  refreshToken   RefreshToken?
  activated      DateTime?
  activationLink ActivationLink?
  avatar         String?
  sockets        Sockets[]
  isOnline       Boolean         @default(false)
}

model Sockets {
  id     String @unique
  user   User   @relation(fields: [userId], references: [id])
  userId Int    @unique
}

model RefreshToken {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId Int    @unique
  token  String @unique

  @@unique([userId, token])
}

model ActivationLink {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId Int    @unique
  link   String

  @@unique([userId, link])
}
