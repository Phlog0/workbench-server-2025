generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String      @id @default(uuid())
  projectType   ProjectType @default(КТП)
  title         String
  description   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime?   @updatedAt
  projectScheme Json?
}

enum ProjectType {
  ТП
  КТП
  РП
}

model User {
  id           Int           @id @default(autoincrement())
  firstName    String
  secondName   String
  password     String
  email        String        @unique
  refreshToken RefreshToken?
}

model RefreshToken {
  id     Int    @id @default(autoincrement())
  user   User   @relation(fields: [userId], references: [id])
  userId Int    @unique
  token  String @unique
}
